# === Gemini API ===
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# === Google Sheets (Service Account) ===
# 1. Crear proyecto en https://console.cloud.google.com/
# 2. APIs & Services → Credentials → Create Service Account
# 3. Generar clave JSON, descargar a ./service_account.json
# 4. Compartir el spreadsheet con el email del service account
GSHEETS_CREDENTIALS_PATH=./service_account.json
GSHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# === Formularios ===
FORM_1_URL=https://forms.gle/oqjtULJ6iGBT7HFR7
FORM_2_URL=https://forms.gle/JQTABscuZxn2S6Dh7
